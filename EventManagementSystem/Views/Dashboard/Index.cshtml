@using EventManagementSystem.DTO
@model DashboardDto

@{
    Layout = "DashboardLayout";
    ViewData["Title"] = "Dashboard";
}

<h2>
    Welcome,
    @(Context.Session.GetString("FirstName") ?? "User") 👋
</h2>

<p>Manage your events and profile here.</p>

<div class="row mt-4">

    <div class="col-md-4 mb-3">
        <div class="card dashboard-card upcoming-card">
            <div class="card-body text-center">
                <h5>Upcoming Events</h5>
                <h2>@Model.UpcomingEvents</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card dashboard-card registered-card">
            <div class="card-body text-center">
                <h5>Registered Events</h5>
                <h2>@Model.RegisteredEvents</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card dashboard-card notification-card">
            <div class="card-body text-center">
                <h5>Notifications</h5>
                <h2>@Model.NotificationsCount</h2>
            </div>
        </div>
    </div>

</div>

<div class="card mt-4 shadow-sm">
    <div class="card-body">
        <h4>Recent Activity</h4>
        <p>No recent activity yet.</p>
    </div>
</div>
