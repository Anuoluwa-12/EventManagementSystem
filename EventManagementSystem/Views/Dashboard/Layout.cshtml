<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Lumievent</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />

    <link rel="stylesheet"
          href="~/css/dashboard.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/css/organizer.css"
          asp-append-version="true" />
</head>

<body>

    <div id="sidebar" class="sidebar">

        <h3 class="text-center mt-4">Lumievent</h3>

        <a asp-controller="Dashboard"
               asp-action="Index">
            Dashboard
        </a>

        @{
            var userRole = Context.Session
                .GetString("UserRole")?
                .Trim();
        }

        <!-- Temporary: shows the current session role -->
        <p style="color: yellow; padding: 5px 20px;">
            Role: @(userRole ?? "No role found")
        </p>

        @if (string.Equals(
                userRole,
                "Admin",
                StringComparison.OrdinalIgnoreCase))
        {
            <a asp-controller="AdminDashboard"
                   asp-action="Index">
                Admin Dashboard
            </a>
        }

        <a asp-controller="Event"
               asp-action="Index">
            My Events
        </a>

        <a asp-controller="Profile"
               asp-action="Index">
            Profile
        </a>

        <a asp-controller="Auth"
               asp-action="Logout">
            Logout
        </a>

        <a asp-controller="Organizer"
               asp-action="Dashboard"
               class="nav-link">
            <i class="fas fa-chart-line"></i>
            <span>Organizer Dashboard</span>
        </a>

        <a asp-controller="Organizer"
               asp-action="Events"
               class="nav-link">
            <i class="fas fa-calendar-days"></i>
            <span>Manage Events</span>
        </a>

        <a asp-controller="Organizer"
               asp-action="CreateEvent"
               class="nav-link">
            <i class="fas fa-calendar-plus"></i>
            <span>Create Event</span>
        </a>

    </div>

    <div id="main" class="main-content">
        @RenderBody()
    </div>      

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
