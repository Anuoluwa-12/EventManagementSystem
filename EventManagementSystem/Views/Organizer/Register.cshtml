@model EventManagementSystem.Models.OrganizerRegistrationViewModel

@{
    ViewData["Title"] = "Become an Organizer";
    Layout = "~/Views/Shared/_OrganizerLayout.cshtml";
}

<div class="organizer-page">

    <div class="row justify-content-center">
        <div class="col-12 col-lg-8 col-xl-6">

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4 p-md-5">

                    <!-- Page heading -->
                    <div class="mb-4">

                        <div class="organizer-summary-icon organizer-icon-events">
                            <i class="fa-solid fa-calendar-check"></i>
                        </div>

                        <h2 class="mb-2">
                            Become an Organizer
                        </h2>

                        <p class="text-muted mb-0">
                            Create an organizer profile to publish and
                            manage events on Lumievent.
                        </p>

                    </div>

                    <form asp-controller="Organizer"
                          asp-action="Register"
                          method="post">

                        <div asp-validation-summary="ModelOnly"
                             class="alert alert-danger">
                        </div>

                        <!-- Organizer name -->
                        <div class="mb-3">

                            <label asp-for="DisplayName"
                                   class="form-label">
                                Organizer Name
                            </label>

                            <input asp-for="DisplayName"
                                   class="form-control"
                                   placeholder="Enter your organizer or business name" />

                            <span asp-validation-for="DisplayName"
                                  class="text-danger">
                            </span>

                            <small class="text-muted d-block mt-1">
                                This name will be displayed publicly on
                                your events.
                            </small>

                        </div>

                        <!-- Phone number -->
                        <div class="mb-3">

                            <label asp-for="Phone"
                                   class="form-label">
                                Phone Number
                            </label>

                            <input asp-for="Phone"
                                   type="tel"
                                   class="form-control"
                                   placeholder="Enter your phone number" />

                            <span asp-validation-for="Phone"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- Organizer bio -->
                        <div class="mb-4">

                            <label asp-for="Bio"
                                   class="form-label">
                                About the Organizer
                            </label>

                            <textarea asp-for="Bio"
                                      class="form-control"
                                      rows="5"
                                      placeholder="Briefly describe your organization and the types of events you organize"></textarea>

                            <span asp-validation-for="Bio"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- Actions -->
                        <div class="d-flex flex-wrap gap-2">

                            <button type="submit"
                                    class="btn btn-primary">

                                <i class="fa-solid fa-user-plus me-1"></i>
                                Register as Organizer
                            </button>

                            <a asp-controller="Dashboard"
                                   asp-action="Index"
                                   class="btn btn-outline-secondary">

                                <i class="fa-solid fa-arrow-left me-1"></i>
                                Back to Dashboard
                            </a>

                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}