@model EventManagementSystem.DTO.ProfileDto

<div class="container mt-5">

    <div class="card p-4">

        <div class="text-center">

            <img src="@(Model.ProfilePictureUrl ?? "/images/default-profile.png")"
                 width="150"
                 height="150"
                 class="rounded-circle" />

            <h3 class="mt-3">
                @Model.FirstName @Model.LastName
            </h3>

            <p>@Model.Email</p>

            <a asp-action="Edit"
                   class="btn btn-primary">
                Edit Profile
            </a>

        </div>

    </div>
    ```

</div>
