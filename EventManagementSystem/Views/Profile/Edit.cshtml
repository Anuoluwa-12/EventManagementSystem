@using EventManagementSystem.DTO;
@model UpdateProfileDto

<h2>Edit Profile</h2>

<form asp-action="Edit"
      method="post"
      enctype="multipart/form-data">


    <div class="mb-3">
        <label>First Name</label>
        <input asp-for="FirstName"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Last Name</label>
        <input asp-for="LastName"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Email</label>
        <input asp-for="Email"
               class="form-control" />
    </div>

    <button class="btn btn-primary">
        Save Changes
    </button>

    <div class="mb-3">
        <label>Profile Picture</label>
        <input asp-for="ProfilePicture"
               type="file"
               class="form-control" />
    </div>
</form>