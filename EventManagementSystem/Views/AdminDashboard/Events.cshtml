@model List<EventManagementSystem.Models.AdminEventViewModel>

@{
    ViewData["Title"] = "Events";
    Layout = "~/Views/Shared/_AdminDashboardLayout.cshtml";
}

<section class="admin-dashboard">

    <div class="dashboard-heading">
        <div>
            <h2>Events</h2>

            <p>
                View all events created on the platform.
            </p>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">

            @if (Model.Count == 0)
            {
                <div class="text-center py-5">
                    <p class="text-muted mb-0">
                        No events were found.
                    </p>
                </div>
            }
            else
            {
                <div class="table-responsive">

                    <table class="table table-hover
                                  align-middle mb-0">

                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Event</th>
                                <th>Organizer</th>
                                <th>Date</th>
                                <th>Venue</th>
                                <th>Price</th>
                                <th>Seats</th>
                                <th class="pe-4">Status</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var eventItem in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <strong>
                                            @eventItem.Title
                                        </strong>
                                    </td>

                                    <td>
                                        @eventItem.OrganizerName
                                    </td>

                                    <td>
                                        @eventItem.EventDate
                                            .ToString("dd MMM yyyy")

                                        <small class="d-block text-muted">
                                            @eventItem.EventTime.ToString("hh\\:mm")
                                        </small>
                                    </td>

                                    <td>
                                        @eventItem.Venue
                                    </td>

                                    <td>
                                        @(eventItem.TicketPrice == 0
                                            ? "Free"
                                            : $"₦{eventItem.TicketPrice:N2}")
                                    </td>

                                    <td>
                                        @eventItem.AvailableSeats
                                        /
                                        @eventItem.TotalSeats
                                    </td>

                                    <td class="pe-4">
                                        <span class="badge bg-primary">
                                            @eventItem.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>

                </div>
            }

        </div>
    </div>

</section>