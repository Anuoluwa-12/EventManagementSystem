@model List<EventManagementSystem.Models.AdminOrganizerViewModel>

@{
    ViewData["Title"] = "Organizers";
    Layout = "~/Views/Shared/_AdminDashboardLayout.cshtml";
}

<section class="admin-dashboard">

    <div class="dashboard-heading">
        <div>
            <h2>Organizers</h2>

            <p>
                View registered organizer profiles and
                their events.
            </p>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">

            @if (Model.Count == 0)
            {
                <div class="text-center py-5">
                    <p class="text-muted mb-0">
                        No organizers were found.
                    </p>
                </div>
            }
            else
            {
                <div class="table-responsive">

                    <table class="table table-hover
                        align-middle mb-0">

                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">
                                    Organizer
                                </th>

                                <th>Email</th>
                                <th>Phone</th>
                                <th>Events</th>
                                <th>Status</th>
                                <th class="pe-4">
                                    Created
                                </th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var organizer in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <strong>
                                            @organizer.DisplayName
                                        </strong>
                                    </td>

                                    <td>
                                        @organizer.Email
                                    </td>

                                    <td>
                                        @(organizer.Phone ?? "—")
                                    </td>

                                    <td>
                                        @organizer.TotalEvents
                                    </td>

                                    <td>
                                        <span class="badge
                                            @(organizer.Status == "Active"
                                                                                              ? "bg-success"
                                                                                              : "bg-secondary")">

                                            @organizer.Status
                                        </span>
                                    </td>

                                    <td class="pe-4">
                                        @organizer.CreatedAt
                                        .ToString("dd MMM yyyy")
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>

                </div>
            }

        </div>
    </div>

</section>