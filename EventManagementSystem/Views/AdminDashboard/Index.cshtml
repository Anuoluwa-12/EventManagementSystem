@model EventManagementSystem.Models.Admin.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Dashboard/Layout.cshtml";
}

<section class="admin-dashboard">

    <div class="dashboard-heading">
        <div>
            <h2>Platform Overview</h2>

            <p>
                Monitor users, bookings, organizers,
                revenue, and events across the platform.
            </p>
        </div>
    </div>

    @if (ViewBag.ErrorMessage is not null)
    {
        <div
            class="alert alert-danger"
            role="alert"
        >
            @ViewBag.ErrorMessage
        </div>
    }

    <div class="row g-4">

        <!-- Total users -->
        <div class="col-12 col-sm-6 col-xl">
            <div class="dashboard-card">
                <div class="dashboard-icon users-icon">
                    <i class="fas fa-users"></i>
                </div>

                <p class="dashboard-label">
                    Total Users
                </p>

                <h3 class="dashboard-value">
                    @Model.TotalUsers.ToString("N0")
                </h3>

                <p class="dashboard-description">
                    Registered platform users
                </p>
            </div>
        </div>

        <!-- Total bookings -->
        <div class="col-12 col-sm-6 col-xl">
            <div class="dashboard-card">
                <div class="dashboard-icon bookings-icon">
                    <i class="fas fa-ticket"></i>
                </div>

                <p class="dashboard-label">
                    Total Bookings
                </p>

                <h3 class="dashboard-value">
                    @Model.TotalBookings.ToString("N0")
                </h3>

                <p class="dashboard-description">
                    Event registrations
                </p>
            </div>
        </div>

        <!-- Total organizers -->
        <div class="col-12 col-sm-6 col-xl">
            <div class="dashboard-card">
                <div class="dashboard-icon organizers-icon">
                    <i class="fas fa-building"></i>
                </div>

                <p class="dashboard-label">
                    Total Organizers
                </p>

                <h3 class="dashboard-value">
                    @Model.TotalOrganizers.ToString("N0")
                </h3>

                <p class="dashboard-description">
                    Registered companies
                </p>
            </div>
        </div>

        <!-- Total revenue -->
        <div class="col-12 col-sm-6 col-xl">
            <div class="dashboard-card">
                <div class="dashboard-icon revenue-icon">
                    <span>₦</span>
                </div>

                <p class="dashboard-label">
                    Total Revenue
                </p>

                <h3 class="dashboard-value revenue-value">
                    ₦@Model.TotalRevenue.ToString("N2")
                </h3>

                <p class="dashboard-description">
                    Revenue from paid registrations
                </p>
            </div>
        </div>

        <!-- Total events -->
        <div class="col-12 col-sm-6 col-xl">
            <div class="dashboard-card">
                <div class="dashboard-icon events-icon">
                    <i class="fas fa-calendar-days"></i>
                </div>

                <p class="dashboard-label">
                    Total Events
                </p>

                <h3 class="dashboard-value">
                    @Model.TotalEvents.ToString("N0")
                </h3>

                <p class="dashboard-description">
                    Events created on the platform
                </p>
            </div>
        </div>

    </div>
</section>