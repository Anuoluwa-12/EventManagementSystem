@{
    var pageTitle =
        ViewData["Title"]?.ToString()
        ?? "Admin Dashboard";

    var currentController =
        ViewContext.RouteData.Values["controller"]?.ToString();

    var currentAction =
        ViewContext.RouteData.Values["action"]?.ToString();

    string ActiveClass(string actionName)
    {
        var isActive =
            string.Equals(
                currentController,
                "AdminDashboard",
                StringComparison.OrdinalIgnoreCase
            )
            &&
            string.Equals(
                currentAction,
                actionName,
                StringComparison.OrdinalIgnoreCase
            );

        return isActive ? "active" : string.Empty;
    }
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@pageTitle - Lumievent Admin</title>

    <!-- Bootstrap -->
    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />

    <!-- Admin dashboard CSS -->
    <link rel="stylesheet"
          href="~/css/admin-dashboard.css"
          asp-append-version="true" />

    <link rel="shortcut icon"
          href="~/favicon.ico" />

    @await RenderSectionAsync(
        "Styles",
        required: false
    )
</head>

<body>

    <div class="admin-layout">

        <!-- Sidebar -->
        <aside class="admin-sidebar"
               id="adminSidebar">

            <div class="admin-brand">

                <a asp-controller="AdminDashboard"
                       asp-action="Index">

                    Lumievent Admin
                </a>

            </div>

            <nav class="admin-navigation">

                <!-- Dashboard -->
                <a asp-controller="AdminDashboard"
                       asp-action="Index"
                       class="admin-nav-link @ActiveClass("Index")">

                    <i class="fa-solid fa-table-columns"></i>

                    <span>
                        Dashboard
                    </span>
                </a>

                <!-- Users -->
                <a asp-controller="AdminDashboard"
                       asp-action="Users"
                       class="admin-nav-link @ActiveClass("Users")">

                    <i class="fa-solid fa-users"></i>

                    <span>
                        Users
                    </span>
                </a>

                <!-- Organizers -->
                <a asp-controller="AdminDashboard"
                       asp-action="Organizers"
                       class="admin-nav-link @ActiveClass("Organizers")">

                    <i class="fa-solid fa-building"></i>

                    <span>
                        Organizers
                    </span>
                </a>

                <!-- Events -->
                <a asp-controller="AdminDashboard"
                       asp-action="Events"
                       class="admin-nav-link @ActiveClass("Events")">

                    <i class="fa-solid fa-calendar-days"></i>

                    <span>
                        Events
                    </span>
                </a>

                <!-- Bookings -->
                <a asp-controller="AdminDashboard"
                       asp-action="Bookings"
                       class="admin-nav-link @ActiveClass("Bookings")">

                    <i class="fa-solid fa-ticket"></i>

                    <span>
                        Bookings
                    </span>
                </a>

                <!-- Payments -->
                <a asp-controller="AdminDashboard"
                       asp-action="Payments"
                       class="admin-nav-link @ActiveClass("Payments")">

                    <i class="fa-solid fa-credit-card"></i>

                    <span>
                        Payments
                    </span>
                </a>

                <!-- Reports -->
                <a asp-controller="AdminDashboard"
                       asp-action="Reports"
                       class="admin-nav-link @ActiveClass("Reports")">

                    <i class="fa-solid fa-chart-line"></i>

                    <span>
                        Reports
                    </span>
                </a>

                <!-- Settings -->
                <a asp-controller="AdminDashboard"
                       asp-action="Settings"
                       class="admin-nav-link @ActiveClass("Settings")">

                    <i class="fa-solid fa-gear"></i>

                    <span>
                        Settings
                    </span>
                </a>

            </nav>

            <div class="admin-sidebar-footer">

                <a asp-controller="Dashboard"
                       asp-action="Index"
                       class="admin-nav-link">

                    <i class="fa-solid fa-arrow-left"></i>

                    <span>
                        User Dashboard
                    </span>
                </a>

                <a asp-controller="Home"
                       asp-action="Index"
                       class="admin-nav-link">

                    <i class="fa-solid fa-house"></i>

                    <span>
                        Back to Website
                    </span>
                </a>

                <a asp-controller="Auth"
                       asp-action="Logout"
                       class="admin-nav-link">

                    <i class="fa-solid fa-right-from-bracket"></i>

                    <span>
                        Logout
                    </span>
                </a>

            </div>

        </aside>

        <!-- Main content -->
        <div class="admin-main">

            <header class="admin-header">

                <div class="d-flex align-items-center gap-3">

                    <button type="button"
                            class="sidebar-toggle d-lg-none"
                            id="sidebarToggle"
                            aria-label="Open admin navigation">

                        <i class="fa-solid fa-bars"></i>
                    </button>

                    <h1 class="admin-header-title">
                        @pageTitle
                    </h1>

                </div>

                <div class="admin-profile">

                    <span class="admin-avatar">
                        A
                    </span>

                    <span class="d-none d-md-inline">
                        Administrator
                    </span>

                </div>

            </header>

            <main class="admin-content">
                @RenderBody()
            </main>

        </div>

    </div>

    <!-- Mobile sidebar overlay -->
    <div class="admin-overlay"
         id="adminOverlay">
    </div>

    <!-- Bootstrap JavaScript -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js">
    </script>

    <script>
            document.addEventListener("DOMContentLoaded", function () {
                const sidebar =
                    document.getElementById("adminSidebar");

                const toggleButton =
                    document.getElementById("sidebarToggle");

                const overlay =
                    document.getElementById("adminOverlay");

                const sidebarLinks =
                    document.querySelectorAll(
                        ".admin-sidebar .admin-nav-link"
                    );

                function openSidebar() {
                    sidebar?.classList.add("is-open");
                    overlay?.classList.add("is-visible");
                    document.body.classList.add(
                        "admin-sidebar-open"
                    );
                }

                function closeSidebar() {
                    sidebar?.classList.remove("is-open");
                    overlay?.classList.remove("is-visible");
                    document.body.classList.remove(
                        "admin-sidebar-open"
                    );
                }

                toggleButton?.addEventListener(
                    "click",
                    function () {
                        if (sidebar?.classList.contains("is-open")) {
                            closeSidebar();
                        }
                        else {
                            openSidebar();
                        }
                    }
                );

                overlay?.addEventListener(
                    "click",
                    closeSidebar
                );

                sidebarLinks.forEach(function (link) {
                    link.addEventListener(
                        "click",
                        closeSidebar
                    );
                });

                document.addEventListener(
                    "keydown",
                    function (event) {
                        if (event.key === "Escape") {
                            closeSidebar();
                        }
                    }
                );

                window.addEventListener(
                    "resize",
                    function () {
                        if (window.innerWidth >= 992) {
                            closeSidebar();
                        }
                    }
                );
            });
    </script>

    @await RenderSectionAsync(
        "Scripts",
        required: false
    )

</body>

</html>