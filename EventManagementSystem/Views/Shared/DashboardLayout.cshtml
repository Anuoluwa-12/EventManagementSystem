@{
    var pageTitle =
        ViewData["Title"]?.ToString()
        ?? "Dashboard";

    var userRole =
        Context.Session.GetString("Role");

    var currentController =
        ViewContext.RouteData.Values["controller"]?
            .ToString();

    string ActiveClass(string controllerName)
    {
        return string.Equals(
            currentController,
            controllerName,
            StringComparison.OrdinalIgnoreCase
        )
            ? "active"
            : string.Empty;
    }
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@pageTitle - Lumievent</title>

    <!-- Bootstrap -->
    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Google Fonts -->
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css?family=Montserrat:600,700,800|Roboto:300,400,700&display=swap" />

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />

    <!-- Theme CSS -->
    <link id="theme-style"
          rel="stylesheet"
          href="~/assets/css/theme.css"
          asp-append-version="true" />

    <!-- Dashboard CSS -->
    <link rel="stylesheet"
          href="~/css/dashboard.css"
          asp-append-version="true" />

    <link rel="shortcut icon"
          href="~/favicon.ico" />

    @await RenderSectionAsync(
        "Styles",
        required: false
    )
</head>

<body>

    <div id="sidebar"
         class="sidebar">

        <div class="dashboard-brand">

            <a asp-controller="Home"
                   asp-action="Index">

                Lumievent
            </a>

        </div>

        <nav class="dashboard-navigation">

            <!-- Normal dashboard -->
            <a asp-controller="Dashboard"
                   asp-action="Index"
                   class="@ActiveClass("Dashboard")">

                <i class="fa-solid fa-house me-2"></i>

                <span>
                    Dashboard
                </span>
            </a>

            <!-- Only visible to administrators -->
            @if (string.Equals(
                            userRole?.Trim(),
                            "Admin",
                            StringComparison.OrdinalIgnoreCase))
            {
                <a asp-controller="AdminDashboard"
                       asp-action="Index"
                       class="admin-dashboard-link
                    @ActiveClass("AdminDashboard")">

                    <i class="fa-solid fa-user-shield me-2"></i>

                    <span>
                        Admin Dashboard
                    </span>
                </a>
            }

            <!-- Organizer dashboard -->
            <a asp-controller="Organizer"
                   asp-action="Dashboard"
                   class="@ActiveClass("Organizer")">

                <i class="fa-solid fa-calendar-check me-2"></i>

                <span>
                    Organizer Dashboard
                </span>
            </a>

            <!-- User events -->
            <a asp-controller="Event"
                   asp-action="Index"
                   class="@ActiveClass("Event")">

                <i class="fa-solid fa-calendar-days me-2"></i>

                <span>
                    My Events
                </span>
            </a>

            <!-- Profile -->
            <a asp-controller="Profile"
                   asp-action="Index"
                   class="@ActiveClass("Profile")">

                <i class="fa-solid fa-user me-2"></i>

                <span>
                    Profile
                </span>
            </a>

            <!-- Website -->
            <a asp-controller="Home"
                   asp-action="Index">

                <i class="fa-solid fa-globe me-2"></i>

                <span>
                    Back to Website
                </span>
            </a>

            <!-- Logout -->
            <a asp-controller="Auth"
                   asp-action="Logout">

                <i class="fa-solid fa-right-from-bracket me-2"></i>

                <span>
                    Logout
                </span>
            </a>

        </nav>

    </div>

    <div class="main-content">

        <button type="button"
                class="menu-btn"
                id="dashboardMenuButton"
                aria-label="Toggle sidebar">

            <i class="fa-solid fa-bars"></i>
        </button>

        @RenderBody()

    </div>

    <div class="dashboard-overlay"
         id="dashboardOverlay">
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js">
    </script>

    <script>
            document.addEventListener(
                "DOMContentLoaded",
                function () {
                    const sidebar =
                        document.getElementById("sidebar");

                    const menuButton =
                        document.getElementById(
                            "dashboardMenuButton"
                        );

                    const overlay =
                        document.getElementById(
                            "dashboardOverlay"
                        );

                    function openSidebar() {
                        sidebar?.classList.add(
                            "show-sidebar"
                        );

                        overlay?.classList.add(
                            "show-overlay"
                        );
                    }

                    function closeSidebar() {
                        sidebar?.classList.remove(
                            "show-sidebar"
                        );

                        overlay?.classList.remove(
                            "show-overlay"
                        );
                    }

                    menuButton?.addEventListener(
                        "click",
                        function () {
                            if (
                                sidebar?.classList.contains(
                                    "show-sidebar"
                                )
                            ) {
                                closeSidebar();
                            }
                            else {
                                openSidebar();
                            }
                        }
                    );

                    overlay?.addEventListener(
                        "click",
                        closeSidebar
                    );

                    document.addEventListener(
                        "keydown",
                        function (event) {
                            if (event.key === "Escape") {
                                closeSidebar();
                            }
                        }
                    );
                }
            );
    </script>

    @await RenderSectionAsync(
        "Scripts",
        required: false
    )

</body>

</html>